{
    "IsoPaths": {
        "NonLTSC": "ISOs\\Win11_Enterprise.iso",
        "LTSC": "ISOs\\Win11_Enterprise_LTSC.iso"
    },
    "TargetBuild": "26100",
    "CopyIsoLocally": true,
    "LocalStagingPath": "C:\\ProgramData\\Win11Upgrade\\stage",
    "LogRoot": "C:\\ProgramData\\Win11Upgrade\\logs",
    "NetworkLogShare": "",
    "UserWarning": {
        "Enabled": true,
        "WarningSeconds": 600,
        "Message": "Your computer will upgrade to Windows 11 in {MINUTES} minutes. Please save your work and close applications. The computer will reboot automatically during the upgrade."
    },
    "SetupArgs": [
        "/auto", "upgrade",
        "/quiet",
        "/eula", "accept",
        "/dynamicupdate", "disable",
        "/showoobe", "none",
        "/telemetry", "disable",
        "/compat", "IgnoreWarning"
    ],
    "MinFreeDiskGB": 25,
    "RequireAC": true,
    "SkipIfAlreadyBuild": true
}
